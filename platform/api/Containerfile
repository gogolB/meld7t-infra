# Accepted production releases archive this image and deploy it by manifest digest.  The base is
# pinned independently so a rebuild cannot silently follow python:3.13-slim to new content.
ARG PYTHON_IMAGE=docker.io/library/python@sha256:eb43ff125d8d58d7449dcba7d336c23bcac412f526d861db493b9994d8010280
FROM ${PYTHON_IMAGE}

ARG BUILD_GIT_SHA=unknown
ARG BUILD_RELEASE=development
LABEL org.opencontainers.image.title="meld7t-api" \
      org.opencontainers.image.revision="$BUILD_GIT_SHA" \
      org.opencontainers.image.version="$BUILD_RELEASE"

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1

RUN groupadd --gid 10001 meld7t \
 && useradd --uid 10001 --gid 10001 --no-create-home --home-dir /app --shell /usr/sbin/nologin meld7t
WORKDIR /app
COPY requirements.lock /opt/meld7t/requirements.lock
COPY wheelhouse /opt/meld7t/wheelhouse
RUN pip install --no-cache-dir --no-index --require-hashes \
      --find-links /opt/meld7t/wheelhouse \
      --requirement /opt/meld7t/requirements.lock \
 && rm -rf /opt/meld7t/wheelhouse
COPY app ./app
COPY alembic ./alembic
COPY alembic.ini entrypoint.sh pyproject.toml ./
RUN chmod 0555 entrypoint.sh \
 && chown -R root:root /app

USER 10001:10001
EXPOSE 8000
ENTRYPOINT ["/app/entrypoint.sh"]
CMD ["serve"]
