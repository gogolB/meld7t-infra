# meld7t reverse proxy (spec §3). Served by the caddy.container Quadlet unit.
# Same-origin paths so Cornerstone/OHIF hit DICOMweb without CORS.
#
# DEFAULT: plain HTTP, catch-all (any host) on the LAN — so a demo is reachable from any device
# (laptop, phone) at http://<host-ip>:9443 with zero cert friction. Self-signed TLS on a bare IP
# fails the SNI handshake and nags every device, so HTTP is the pragmatic default for a trusted
# intranet demo with non-clinical pilot data.
#
# PRODUCTION HARDENING → switch to HTTPS: give the host a resolvable name, set SITE_ADDRESS to it
# in services.env, and replace each `http://:PORT` site header below with `{$SITE_ADDRESS}` (adding
# `tls internal` for Caddy's local CA, or `tls <cert> <key>` for institutional PKI). A hostname
# sends SNI, so the internal cert resolves correctly (an IP does not).

{
	admin off
	auto_https off
}

# --- Shell + API (port 9443) ---
http://:9443 {
	encode zstd gzip

	# DICOMweb (QIDO/WADO/STOW) → Orthanc. Path preserved (Orthanc DicomWeb Root is /dicom-web/).
	handle /dicom-web/* {
		reverse_proxy orthanc:8042
	}

	# Application API → FastAPI orchestration (§5).
	handle /api/* {
		reverse_proxy api:8000
	}

	# Static SPA shell (built by `just web-build` → platform/web/dist, mounted at /srv/spa; §9.4).
	handle {
		root * /srv/spa
		try_files {path} /index.html
		file_server
	}
}

# --- OHIF viewer on its own origin (port 9444) so its root-absolute assets don't collide with the
# shell. DICOMweb is same-origin here → no CORS (§9). The Review screen iframes it. ---
http://:9444 {
	encode zstd gzip

	handle /dicom-web/* {
		reverse_proxy orthanc:8042
	}
	handle {
		reverse_proxy ohif:80
	}
}
