# meld7t reverse proxy (spec §3). Served by the caddy.container Quadlet unit.
# Same-origin paths so Cornerstone/OHIF hit DICOMweb without CORS.

{
	# Air-gapped: no ACME. TLS is issued/renewed by Caddy's built-in local CA (see the
	# site's `tls internal` below). The CA root is stored in the caddy-data volume —
	# distribute it to intranet clients, or swap `tls internal` for institutional PKI.
	admin off
}

# SITE_ADDRESS is injected from services.env (default: localhost). Use the intranet
# hostname clients actually resolve, so the internal cert's SAN matches.
{$SITE_ADDRESS:localhost} {
	tls internal

	encode zstd gzip

	# DICOMweb (QIDO/WADO/STOW) → Orthanc. Path is preserved (Orthanc's DicomWeb Root is
	# /dicom-web/), so this is a same-origin passthrough for the viewer. (§3, §4)
	handle /dicom-web/* {
		reverse_proxy orthanc:8042
	}

	# Application API → FastAPI orchestration (§5).
	handle /api/* {
		reverse_proxy api:8000
	}

	# Static SPA shell, built on the dev machine and staged as a mounted volume (§9.4).
	handle {
		root * /srv/spa
		try_files {path} /index.html
		file_server
	}
}

# OHIF viewer on its own origin (dedicated port) so its root-absolute assets don't collide
# with the shell. DICOMweb is same-origin here → no CORS (§9.4). The shell iframes it.
{$SITE_ADDRESS:localhost}:8444 {
	tls internal
	encode zstd gzip

	handle /dicom-web/* {
		reverse_proxy orthanc:8042
	}
	handle {
		reverse_proxy ohif:80
	}
}
