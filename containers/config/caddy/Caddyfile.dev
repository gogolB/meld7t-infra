# Developer-only cleartext edge.  Production installs `Caddyfile`, never this file.
{
	admin off
	auto_https off
}

http://:9443 {
	encode zstd gzip
	handle /dicom-web/* {
		reverse_proxy orthanc:8042
	}
	handle /api/* {
		reverse_proxy api:8000
	}
	handle {
		root * /srv/spa
		try_files {path} /index.html
		file_server
	}
}

http://:9444 {
	encode zstd gzip
	handle /dicom-web/* {
		reverse_proxy orthanc:8042
	}
	handle {
		reverse_proxy ohif:80
	}
}
