# meld7t long-running services — environment/secrets template.
#
# Copy to secrets/services.env (gitignored) and fill in real values; bootstrap installs it
# to ~/.config/meld7t/services.env (mode 0600) where the Quadlet units read it. Generate
# passwords with e.g.  openssl rand -base64 24
#
# One shared file for MVP simplicity. §27 (least-privilege) splits secrets per service later.

# --- PostgreSQL superuser (postgres.container) ---
POSTGRES_PASSWORD=CHANGE_ME_postgres_superuser

# --- Orthanc's DB role. This exact var name is also injected into Orthanc's PostgreSQL
#     plugin config by the orthancteam image (ORTHANC__SECTION__KEY convention), and the
#     postgres init script creates the `orthanc` role with the same value. Keep them one. ---
ORTHANC__POSTGRESQL__PASSWORD=CHANGE_ME_orthanc_db_role

# --- Application (FastAPI/SQLModel) DB role: `meld` database ---
MELD_DB_PASSWORD=CHANGE_ME_meld_db_role

# --- Caddy: the intranet hostname it serves + issues an internal cert for (spec §3).
#     Use the name clients actually resolve; localhost is fine for a single-box demo. ---
SITE_ADDRESS=localhost

# --- immudb audit ledger (spec §26). First-boot admin password (container) + the api's copy. ---
IMMUDB_ADMIN_PASSWORD=CHANGE_ME_immudb_admin
MELD7T_IMMUDB_PASSWORD=CHANGE_ME_immudb_admin   # must equal IMMUDB_ADMIN_PASSWORD
MELD7T_AUDIT_REQUIRE_IMMUDB=true                 # prod: fail closed if the ledger is unreachable

# --- api (FastAPI) connection strings (spec §5). The meld password below must match
#     MELD_DB_PASSWORD above. ---
MELD7T_DB_URL=postgresql+psycopg://meld:CHANGE_ME_meld_db_role@postgres:5432/meld
MELD7T_REDIS_URL=redis://redis:6379/0
MELD7T_ORTHANC_DICOMWEB=http://orthanc:8042/dicom-web
