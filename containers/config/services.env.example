# Developer-workstation convenience only.  Production uses the split examples under
# containers/config/production/ and ansible/production.yml.  Keep comments on their own lines:
# systemd EnvironmentFile does not support shell-style trailing comments.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_postgres_superuser
ORTHANC__POSTGRESQL__PASSWORD=CHANGE_ME_orthanc_db_role
MELD_DB_PASSWORD=CHANGE_ME_meld_db_role
REDIS_PASSWORD=CHANGE_ME_redis
IMMUDB_ADMIN_PASSWORD=CHANGE_ME_immudb_admin

MELD7T_DEPLOYMENT_MODE=development
MELD7T_AUTH_DEV_BYPASS=true
MELD7T_DB_URL=postgresql+psycopg://meld:CHANGE_ME_meld_db_role@postgres:5432/meld
MELD7T_REDIS_URL=redis://:CHANGE_ME_redis@redis:6379/0
MELD7T_ORTHANC_DICOMWEB=http://orthanc:8042/dicom-web
MELD7T_CASE_UPLOAD_ROOT=/data/case-uploads
MELD7T_IMMUDB_PASSWORD=CHANGE_ME_immudb_admin
MELD7T_AUDIT_REQUIRE_IMMUDB=false
MELD7T_BRANDING_LOGO_URL=/branding/report-logo.png
MELD7T_BRANDING_LOGO_PATH=/run/branding/report-logo.png

SITE_ADDRESS=localhost
