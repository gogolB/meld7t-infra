# Copy to ~/meld7t-secrets/production/postgres.env with mode 0600. Values must be URL-safe strings
# or separately percent-encoded when copied into API/worker database URLs.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_WITH_RANDOM_POSTGRES_SUPERUSER_SECRET
POSTGRES_INITDB_ARGS=--auth-host=scram-sha-256 --data-checksums
ORTHANC__POSTGRESQL__PASSWORD=REPLACE_WITH_RANDOM_ORTHANC_ROLE_SECRET
MELD_DB_PASSWORD=REPLACE_WITH_RANDOM_MELD_ROLE_SECRET
