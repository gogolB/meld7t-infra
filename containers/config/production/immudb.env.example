# First-boot administrator credential.  After bootstrap, create a dedicated append/verify runtime
# principal and place that principal in api.env and worker.env; do not distribute this admin secret.
IMMUDB_ADMIN_PASSWORD=REPLACE_WITH_RANDOM_IMMUDB_ADMIN_SECRET
IMMUDB_AUTH=true
IMMUDB_DEVMODE=false
IMMUDB_MAINTENANCE=false
IMMUDB_SIGNINGKEY=/run/secrets/immudb-signing-private.pem
