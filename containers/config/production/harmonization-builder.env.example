# Builder-specific settings. The service also reads validated worker.env and runtime-images.env.
MELD7T_DEPLOYMENT_MODE=production
# Override research-case Orthanc values inherited from worker.env; this service must never use it.
MELD7T_ORTHANC_DICOMWEB=http://127.0.0.1:9/disabled
MELD7T_ORTHANC_INNET=http://127.0.0.1:9/disabled
MELD7T_HARMONIZATION_ORTHANC_DICOMWEB=http://127.0.0.1:8043/dicom-web
MELD7T_HARMONIZATION_ORTHANC_REST=http://127.0.0.1:8043
MELD7T_HARMONIZATION_ORTHANC_USER=harmonization-builder
MELD7T_HARMONIZATION_ORTHANC_PASSWORD=REPLACE_WITH_SAME_HARMONIZATION_BUILDER_HTTP_SECRET
MELD7T_HARMONIZATION_UPLOAD_ROOT=/var/home/OPERATOR/meld7t-state/harmonization-uploads
MELD7T_HARMONIZATION_BUILD_ROOT=/var/home/OPERATOR/meld7t-state/harmonization-builds
MELD7T_HARMONIZATION_GENERATED_ROOT=/var/home/OPERATOR/meld7t-state/harmonization-profiles
MELD7T_HARMONIZATION_MAX_UPLOAD_BYTES=536870912000
MELD7T_HARMONIZATION_UPLOAD_MAX_FILES=100000
MELD7T_HARMONIZATION_UPLOAD_MAX_EXPANDED_BYTES=536870912000
MELD7T_HARMONIZATION_BUILDER_QUEUE=harmonization-builder
MELD7T_HARMONIZATION_BUILDER_MAX_JOBS=2
MELD7T_HARMONIZATION_BUILDER_TIMEOUT_S=172800
MELD7T_HARMONIZATION_BUILDER_LEASE_S=180
MELD7T_HARMONIZATION_BUILDER_HEARTBEAT_S=30
# Set only after a site-reviewed regular non-symlink executable has passed acceptance; deployment
# hashes its bytes and copies this digest into api.env for build admission.
# MELD7T_HARMONIZATION_BUILDER_ADAPTER=/opt/meld7t/bin/site-meld-builder-adapter
# MELD7T_HARMONIZATION_BUILDER_ADAPTER_SHA256=REPLACE_WITH_64_HEX_REVIEWED_ADAPTER_DIGEST
MELD7T_HARMONIZATION_MAX_INSTANCE_BYTES=17179869184
MELD7T_HARMONIZATION_BUILD_MAX_BYTES=1099511627776
MELD7T_HARMONIZATION_FAILED_WORKSPACE_RETENTION_HOURS=24
MELD7T_HARMONIZATION_ALLOWED_PRIVATE_TAGS=[]
MELD7T_HARMONIZATION_ALLOWED_TRANSFER_SYNTAXES=["1.2.840.10008.1.2","1.2.840.10008.1.2.1","1.2.840.10008.1.2.2","1.2.840.10008.1.2.1.99","1.2.840.10008.1.2.4.70","1.2.840.10008.1.2.4.80","1.2.840.10008.1.2.4.90","1.2.840.10008.1.2.5"]
MELD7T_STORAGE_MIN_FREE_BYTES=107374182400
MELD7T_STORAGE_MIN_FREE_PERCENT=10
MELD7T_WORKER_MAX_JOBS=1
MELD7T_IMMUDB_ROOT_STATE_PATH=/var/home/OPERATOR/meld7t-state/audit/harmonization-builder.root
