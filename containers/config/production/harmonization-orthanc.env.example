# Only the API and builder receive these distinct credentials. Copy with mode 0600.
ORTHANC__POSTGRESQL__PASSWORD=REPLACE_WITH_SAME_HARMONIZATION_ORTHANC_ROLE_SECRET
ORTHANC__AUTHENTICATION_ENABLED=true
# Hard cap in MiB for the quarantine/control store; adjust downward to the accepted host budget.
ORTHANC__MAXIMUM_STORAGE_SIZE=2097152
ORTHANC__MAXIMUM_STORAGE_MODE=Reject
ORTHANC__REGISTERED_USERS={"harmonization-api":"REPLACE_WITH_RANDOM_HARMONIZATION_API_HTTP_SECRET","harmonization-builder":"REPLACE_WITH_RANDOM_HARMONIZATION_BUILDER_HTTP_SECRET"}
