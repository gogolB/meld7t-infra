# Host-facing service URLs use the loopback-only published ports.  Image values are installed from
# the signed images.lock into a separate runtime-images.env and intentionally do not appear here.
MELD7T_DEPLOYMENT_MODE=production
MELD7T_AUTH_TRUSTED_PROXY_NETWORKS=["127.0.0.1/32"]
MELD7T_AUTH_PROXY_SHARED_SECRET=REPLACE_WITH_RANDOM_UNUSED_WORKER_VALIDATION_SECRET_32_CHARS
MELD7T_DB_URL=postgresql+psycopg://meld:REPLACE_WITH_PERCENT_ENCODED_MELD_SECRET@127.0.0.1:5432/meld
MELD7T_REDIS_URL=redis://:REPLACE_WITH_PERCENT_ENCODED_REDIS_SECRET@127.0.0.1:6379/0
MELD7T_ORTHANC_DICOMWEB=http://meld-internal:REPLACE_WITH_PERCENT_ENCODED_ORTHANC_HTTP_SECRET@127.0.0.1:8042/dicom-web
MELD7T_IMMUDB_HOST=127.0.0.1
MELD7T_IMMUDB_PORT=3322
MELD7T_IMMUDB_USER=meld7t-runtime
MELD7T_IMMUDB_PASSWORD=REPLACE_WITH_RUNTIME_IMMUDB_SECRET
MELD7T_IMMUDB_DB=defaultdb
MELD7T_IMMUDB_ROOT_STATE_PATH=/var/home/OPERATOR/meld7t-state/audit/worker.root
MELD7T_IMMUDB_PUBLIC_KEY_PATH=/var/home/OPERATOR/.config/meld7t/current/trust/immudb-signing-public.pem
MELD7T_AUDIT_REQUIRE_IMMUDB=true
MELD7T_AUDIT_HMAC_KEY=REPLACE_WITH_SAME_AUDIT_HMAC_SECRET_AS_API
MELD7T_REPO_DIR=/var/home/OPERATOR/.local/lib/meld7t/current
MELD7T_MELD_DATA=/var/home/OPERATOR/meld7t-state/meld-data
MELD7T_DICOM_STAGING=/var/home/OPERATOR/meld7t-state/meld-data/staging
MELD7T_DICOM_IMPORT_ROOT=/var/home/OPERATOR/meld7t/data/raw
MELD7T_DICOM_MAX_BYTES_PER_RUN=107374182400
MELD7T_STORAGE_MIN_FREE_BYTES=53687091200
MELD7T_STORAGE_MIN_FREE_PERCENT=10
MELD7T_STORAGE_OUTPUT_HEADROOM_BYTES=26843545600
MELD7T_WORKER_MAX_JOBS=2
MELD7T_HARMONIZATION_ROOT=/var/home/OPERATOR/meld7t-state/meld-data/harmonization
MELD7T_HARMONIZATION_GENERATED_ROOT=/var/home/OPERATOR/meld7t-state/harmonization-profiles
MELD7T_FS_LICENSE=/var/home/OPERATOR/.config/meld7t/licenses/freesurfer.txt
MELD7T_MELD_LICENSE=/var/home/OPERATOR/.config/meld7t/licenses/meld.txt
MELD7T_HIPPUNFOLD_CACHE=hippunfold-cache
MELD7T_ORTHANC_INNET=http://meld-internal:REPLACE_WITH_PERCENT_ENCODED_ORTHANC_HTTP_SECRET@orthanc:8042/dicom-web
MELD7T_RELEASE_MANIFEST_DIGEST=REPLACE_WITH_64_HEX_RELEASE_MANIFEST_DIGEST
MELD7T_GIT_SHA=REPLACE_FROM_SIGNED_RELEASE
MELD7T_OS_CHECKSUM=REPLACE_FROM_BOOTED_OSTREE_DEPLOYMENT
MELD7T_WORKER_VENV=/var/home/OPERATOR/.local/lib/meld7t/worker-venv
