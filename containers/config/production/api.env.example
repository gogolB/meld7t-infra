MELD7T_DEPLOYMENT_MODE=production
MELD7T_AUTH_DEV_BYPASS=false
MELD7T_AUTH_TRUSTED_PROXY_NETWORKS=["10.89.10.0/24"]
MELD7T_AUTH_PROXY_SHARED_SECRET=REPLACE_WITH_RANDOM_32_PLUS_CHARACTER_PROXY_SECRET
MELD7T_AUTH_LOCAL_TOKENS=[]
MELD7T_DB_URL=postgresql+psycopg://meld:REPLACE_WITH_PERCENT_ENCODED_MELD_SECRET@postgres:5432/meld
MELD7T_REDIS_URL=redis://:REPLACE_WITH_PERCENT_ENCODED_REDIS_SECRET@redis:6379/0
MELD7T_ORTHANC_DICOMWEB=http://meld-internal:REPLACE_WITH_PERCENT_ENCODED_ORTHANC_HTTP_SECRET@orthanc:8042/dicom-web
MELD7T_CASE_UPLOAD_ROOT=/data/case-uploads
MELD7T_CASE_UPLOAD_MAX_BYTES=107374182400
MELD7T_CASE_UPLOAD_QUOTA_BYTES=536870912000
MELD7T_CASE_UPLOAD_CHUNK_BYTES=67108864
MELD7T_CASE_UPLOAD_EXPIRY_HOURS=24
MELD7T_CASE_REPORT_TIMEOUT_MINUTES=30
MELD7T_HARMONIZATION_ORTHANC_DICOMWEB=http://harmonization-orthanc:8042/dicom-web
MELD7T_HARMONIZATION_ORTHANC_USER=harmonization-api
MELD7T_HARMONIZATION_ORTHANC_PASSWORD=REPLACE_WITH_SAME_HARMONIZATION_API_HTTP_SECRET
MELD7T_HARMONIZATION_UPLOAD_ROOT=/data/harmonization-uploads
MELD7T_HARMONIZATION_GENERATED_ROOT=/data/generated-harmonization
MELD7T_HARMONIZATION_MAX_UPLOAD_BYTES=536870912000
MELD7T_HARMONIZATION_COHORT_QUOTA_BYTES=1099511627776
MELD7T_HARMONIZATION_UPLOAD_CHUNK_BYTES=67108864
MELD7T_HARMONIZATION_BUILDER_QUEUE=harmonization-builder
MELD7T_HARMONIZATION_BUILDER_LEASE_S=180
MELD7T_HARMONIZATION_BUILDER_HEARTBEAT_S=30
MELD7T_HARMONIZATION_BUILDER_HEARTBEAT_KEY=meld7t:harmonization-builder:heartbeat
MELD7T_HARMONIZATION_BUILDER_HEARTBEAT_MAX_AGE_S=60
# Set to the same reviewed adapter digest as harmonization-builder.env when the adapter is enabled.
# MELD7T_HARMONIZATION_BUILDER_ADAPTER_SHA256=REPLACE_WITH_64_HEX_REVIEWED_ADAPTER_DIGEST
MELD7T_HARMONIZATION_MAX_INSTANCE_BYTES=17179869184
# Exact site-reviewed vendor-private tags only; empty is the safe default.
MELD7T_HARMONIZATION_ALLOWED_PRIVATE_TAGS=[]
MELD7T_HARMONIZATION_ALLOWED_TRANSFER_SYNTAXES=["1.2.840.10008.1.2","1.2.840.10008.1.2.1","1.2.840.10008.1.2.2","1.2.840.10008.1.2.1.99","1.2.840.10008.1.2.4.70","1.2.840.10008.1.2.4.80","1.2.840.10008.1.2.4.90","1.2.840.10008.1.2.5"]
MELD7T_IMMUDB_HOST=immudb
MELD7T_IMMUDB_PORT=3322
MELD7T_IMMUDB_USER=meld7t-runtime
MELD7T_IMMUDB_PASSWORD=REPLACE_WITH_RUNTIME_IMMUDB_SECRET
MELD7T_IMMUDB_DB=defaultdb
MELD7T_IMMUDB_ROOT_STATE_PATH=/var/lib/meld7t/immudb-state/api.root
MELD7T_IMMUDB_PUBLIC_KEY_PATH=/run/secrets/immudb-public-key.pem
MELD7T_AUDIT_REQUIRE_IMMUDB=true
MELD7T_AUDIT_HMAC_KEY=REPLACE_WITH_RANDOM_32_PLUS_CHARACTER_AUDIT_HMAC_SECRET
MELD7T_HARMONIZATION_REQUIRED=true
# The production installer overwrites this only from the signed release authorization.
MELD7T_HARMONIZATION_COHORT_BOOTSTRAP_ALLOWED=false
MELD7T_HARMONIZATION_ROOT=/data/harmonization
MELD7T_HARMONIZATION_EXPECTED_PROFILES=REPLACE_FROM_SIGNED_EXPECTED_ACTIVE_PROFILES_COMPACT_JSON
MELD7T_RELEASE_MANIFEST_DIGEST=REPLACE_WITH_64_HEX_RELEASE_MANIFEST_DIGEST
MELD7T_AUTO_MIGRATE=false
MELD7T_BRANDING_PRODUCT_NAME="MELD 7T"
MELD7T_BRANDING_INSTITUTION_NAME="Houston Methodist"
MELD7T_BRANDING_DEPARTMENT_NAME="Houston Methodist Research Institute"
MELD7T_BRANDING_LOGO_URL=/branding/report-logo.png
MELD7T_BRANDING_LOGO_PATH=/run/branding/report-logo.png
MELD7T_BRANDING_PRIMARY_COLOR=#124A7E
MELD7T_BRANDING_SECONDARY_COLOR=#749ABB
MELD7T_BRANDING_FOOTER_TEXT="Houston Methodist Research Institute"
