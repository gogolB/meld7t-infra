[Unit]
Description=meld-compute — isolated ephemeral packaging network

[Network]
# Do not silently reuse the pre-hardening meld-net (10.89.0.0/24) during an upgrade.
NetworkName=meld-compute-net
Driver=bridge
Internal=true
Subnet=10.89.30.0/24
Options=isolate=true

[Install]
WantedBy=default.target
