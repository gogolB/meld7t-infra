[Unit]
Description=Orthanc — internal DICOM store and DICOMweb
Wants=postgres.service
After=network-online.target postgres.service

[Container]
Image=docker.io/orthancteam/orthanc@sha256:57a3d037729897331027ddc00c12695b50f1effbbf805f855396f3d0248d2d5f
Pull=never
ContainerName=orthanc
Network=meld-edge.network
Network=meld-data.network
Network=meld-net.network
Volume=orthanc-storage.volume:/var/lib/orthanc/db
Volume=%h/.config/meld7t/current/orthanc/orthanc.json:/etc/orthanc/orthanc.json:ro,z
PublishPort=127.0.0.1:8042:8042
EnvironmentFile=%h/.config/meld7t/current/env/orthanc.env
HealthCmd=python3 -c 'import base64,json,os,urllib.request; u=json.loads(os.environ["ORTHANC__REGISTERED_USERS"]); r=urllib.request.Request("http://127.0.0.1:8042/system",headers={"Authorization":"Basic "+base64.b64encode(("meld-internal:"+u["meld-internal"]).encode()).decode()}); urllib.request.urlopen(r,timeout=3).read()'
HealthInterval=30s
HealthTimeout=5s
HealthStartPeriod=60s
HealthRetries=5
HealthOnFailure=kill
Notify=healthy
NoNewPrivileges=true
PidsLimit=1024
LogDriver=journald

[Service]
Restart=always
RestartSec=10
TimeoutStartSec=300
TimeoutStopSec=120
StartLimitIntervalSec=600
StartLimitBurst=10
MemoryHigh=2G
MemoryMax=4G
TasksMax=1536
CPUWeight=150
IOWeight=250

[Install]
WantedBy=default.target
