# Personal CLI convenience tools (NOT the pipeline — the scientific stack lives in containers).
# Install:  brew bundle --file=Brewfile
brew "just"      # the task runner used by ./justfile
brew "jq"        # JSON wrangling
brew "gh"        # GitHub CLI
brew "ripgrep"   # fast search
brew "fd"        # fast find
brew "btop"      # system/GPU monitor
brew "uv"        # fast Python env/dependency manager (handy inside the dev box too)

